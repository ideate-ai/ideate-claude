{
  "name": "@ideate/artifact-server",
  "version": "3.11.0",
  "description": "MCP server that serves ideate artifact content on demand",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm src/index.ts",
    "pretest": "node scripts/pretest.js",
    "test": "tsc --noEmit && vitest run",
    "build:migration": "tsc ../../scripts/migrate-to-v3.ts --target ES2022 --module NodeNext --moduleResolution NodeNext --esModuleInterop --skipLibCheck --outDir ../../scripts --declaration false",
    "prebuild:migration": "node -e \"['../../scripts/migrate-to-v3.d.ts','../../scripts/migrate-to-v3.d.ts.map','../../scripts/migrate-to-v3.js.map'].forEach(f=>{try{require('fs').rmSync(f)}catch(e){}})\"",
    "test:coverage": "vitest run --coverage",
    "test:equivalence": "docker compose -f docker-compose.test.yml up -d && scripts/wait-for-healthy.sh docker-compose.test.yml 180; EXIT=$?; if [ $EXIT -eq 0 ]; then vitest run --reporter=verbose --no-file-parallelism tests/adapters/equivalence*.test.ts; EXIT=$?; fi; docker compose -f docker-compose.test.yml down; exit $EXIT"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^3.6.0",
    "drizzle-orm": "^0.45.1",
    "js-tiktoken": "^1.0.16",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
